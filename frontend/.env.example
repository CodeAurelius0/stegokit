# Required when the frontend is deployed separately from the API.
# Example: https://stegokit-api.onrender.com/api
VITE_API_URL=

# Use /stegokit/ for GitHub Pages project sites. Use / for single-service deploys.
VITE_BASE_PATH=/

# Local dev proxy target. The frontend calls /api in development.
VITE_DEV_API_PROXY=http://localhost:5000
